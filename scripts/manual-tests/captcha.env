# Captcha on, verifying against Cloudflare's documented "always passes" test
# secret. Real network call, real siteverify endpoint — that is the point: it
# proves the whole chain (token → server → Cloudflare → accept) is connected,
# which is exactly what was broken.
#
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_ENFORCE=true
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_BYPASS_LOCALHOST=false
