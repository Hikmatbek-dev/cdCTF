# Captcha enforced but no secret key: a half-finished deploy.
#
# The question this answers is which way that fails. Accepting registrations
# because the server cannot check them would be the worst outcome — protection
# that silently isn't. No network call: the server has nothing to call with.
TURNSTILE_ENFORCE=true
TURNSTILE_BYPASS_LOCALHOST=false
# Set empty on purpose, not merely left out: a developer with this exported in
# their shell would otherwise inherit it and quietly test the wrong thing.
TURNSTILE_SECRET_KEY=
