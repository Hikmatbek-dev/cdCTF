{
  "version": 2,
  "installCommand": "corepack pnpm install --frozen-lockfile",
  "buildCommand": "corepack pnpm run build",
  "outputDirectory": "artifacts/cyberplace/dist/public",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/((?!assets/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/healthz",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/competitions/:id(\\d+)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(TelegramBot|facebookexternalhit|Twitterbot|WhatsApp|Slackbot|Discordbot|LinkedInBot|vkShare|Pinterest|redditbot|Applebot|SkypeUriPreview|Googlebot|bingbot).*"
        }
      ],
      "destination": "/api/og/competition/:id"
    },
    {
      "source": "/profile/:id(\\d+)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(TelegramBot|facebookexternalhit|Twitterbot|WhatsApp|Slackbot|Discordbot|LinkedInBot|vkShare|Pinterest|redditbot|Applebot|SkypeUriPreview|Googlebot|bingbot).*"
        }
      ],
      "destination": "/api/og/profile/:id"
    },
    {
      "source": "/talent",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(TelegramBot|facebookexternalhit|Twitterbot|WhatsApp|Slackbot|Discordbot|LinkedInBot|vkShare|Pinterest|redditbot|Applebot|SkypeUriPreview|Googlebot|bingbot).*"
        }
      ],
      "destination": "/api/og/talent"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
