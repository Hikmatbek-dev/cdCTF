# Copy to .env and fill in. Never commit the real file.

# --- Required ---------------------------------------------------------------

DATABASE_URL=postgresql://postgres:password@localhost:5432/cyberplace
PORT=8080

# Signs session tokens. Required in production; the server refuses to start
# without it there, and demands at least 32 characters.
JWT_SECRET=

# Encrypts TOTP secrets at rest. Required in production, same rules as above.
#
# Deliberately separate from JWT_SECRET: rotating the signing key should not
# brick every enrolled authenticator. LOSING THIS LOCKS EVERY 2FA USER OUT —
# they would have to use a backup code and re-enrol. Back it up.
TOTP_ENCRYPTION_KEY=

# --- OAuth (optional) -------------------------------------------------------
#
# A provider only appears on the login page once both of its values are set.
#
# Register the callback URL with each provider EXACTLY as:
#   <APP_BASE_URL>/api/auth/oauth/<provider>/callback
#
# Production:  https://cdctf.vercel.app/api/auth/oauth/google/callback
# Local:       http://localhost:5173/api/auth/oauth/google/callback
#
# Compared character for character. The two that bite:
#   - https, not http, for anything on Vercel — it does not serve plain http
#   - one slash before /api, not two
#
# Google:  https://console.cloud.google.com/apis/credentials
# GitHub:  https://github.com/settings/developers
# Discord: https://discord.com/developers/applications

# Local dev; in production set this to https://cdctf.vercel.app
APP_BASE_URL=http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Captcha on registration (optional) -------------------------------------
#
# Cloudflare Turnstile. Keys: https://dash.cloudflare.com/?to=/:account/turnstile
#
# Three switches, and all three matter:
#   - VITE_TURNSTILE_SITE_KEY  makes the widget appear. Without it the frontend
#                              sends no token, so the two below do nothing.
#   - TURNSTILE_SECRET_KEY     lets the server verify a token it is sent.
#   - TURNSTILE_ENFORCE        rejects registration when the token is missing or
#                              invalid. Off means a token is checked if present
#                              and ignored otherwise — that is not protection.
#
# So bot protection is only actually on when all three are set in production.

VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ENFORCE=false

# Skips the captcha for requests from localhost, so local registration does not
# need real keys. The server ignores this entirely when NODE_ENV=production, so
# setting it there is a no-op rather than a hole.
TURNSTILE_BYPASS_LOCALHOST=false

# --- Email (Resend) ---------------------------------------------------------
#
# Verification and password-reset mail. Key: https://resend.com/api-keys
# The From address must be on a domain verified in Resend, or it refuses to send.
#
# Without both of these the server cannot mail anyone, and what happens then
# depends entirely on the switch below — read it before setting it.

RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Whether an account is worthless until its email is confirmed.
#
# OFF (default): if the mail cannot be sent, registration succeeds anyway and
# the account is marked verified. So with no Resend key, anyone registers
# instantly with an address they do not own.
#
# ON: if the mail cannot be sent, the new account is DELETED and registration
# answers 503. Turning this on without a working Resend key does not tighten
# signup — it stops signup completely, for everyone.
#
# So: set the two keys above, send yourself a test registration, and only then
# turn this on.
EMAIL_VERIFICATION_REQUIRED=false

# --- File storage (Supabase) ------------------------------------------------
#
# Where CTF attachments and avatars live.
# Settings -> API in the Supabase dashboard; the service_role key, not anon.
#
# Unset on serverless, uploads fall back to base64 inside Postgres — there is no
# disk that survives a cold start. That works, which is the trap: nothing fails,
# and 25MB challenge files quietly pile into the database and every backup, a
# third larger than the file itself. The server logs a warning each time.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Defaults to "cdctf". Create the bucket in the dashboard first.
SUPABASE_STORAGE_BUCKET=cdctf

# --- Error reporting (Sentry, optional) --------------------------------------
#
# Both are optional and independent; unset, errors are only logged locally.
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Optional ---------------------------------------------------------------

# Comma-separated extra origins allowed through CORS. The localhost defaults are
# development-only and are dropped when NODE_ENV=production.
CORS_ORIGINS=

# pino log level: trace, debug, info, warn, error, fatal. Defaults to info.
LOG_LEVEL=info

# Max JSON/form body size. Defaults to 10mb. Note this is separate from the 25MB
# ceiling on CTF file uploads, which lives in storage.ts.
REQUEST_BODY_LIMIT=10mb

# Where uploads land in local development. Ignored once Supabase Storage is
# configured, and useless on serverless, which has no persistent disk.
LOCAL_UPLOAD_DIR=

# Session lifetime. Defaults to 30 days.
AUTH_SESSION_MAX_AGE_DAYS=30

# Set to "none" only when the frontend and API are on different domains.
#
# This used to warn that "none" makes every state-changing request forgeable,
# since there are no CSRF tokens here. That is not true, and was worth checking
# rather than believing: with the cookie at SameSite=none, a forged request from
# another origin still gets 403, because the CORS allowlist rejects an unknown
# Origin on real requests and not only on preflights. SameSite=lax is the second
# lock, not the only one. scripts/manual-tests/csrf.sh holds both shut.
#
# Still prefer "lax" where the domains allow it — defence in depth is the point.
AUTH_COOKIE_SAME_SITE=lax
